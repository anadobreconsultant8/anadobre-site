---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Servicii — Ana Dobre | Automatizări Marketing & Vânzări"
  description="Audit, implementare și optimizare continuă a sistemelor de marketing și vânzări. Planific, implementez și optimizez automatizări pentru companii cu 50+ lead-uri lunar."
>
  <Navbar />

  <!-- HERO -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="inline-block bg-bg-tertiary text-primary text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-6">
        Servicii
      </div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-primary leading-tight mb-6">
        Un sistem de marketing și vânzări<br />
        care produce clienți, nu doar lead-uri.
      </h1>
      <p class="text-lg md:text-xl text-text-secondary leading-relaxed max-w-2xl mx-auto">
        Planific, implementez și optimizez sisteme automatizate pentru companii care au depășit etapa de validare și vor performanță din procesele lor existente.
      </p>
    </div>
  </section>

  <!-- PENTRU CINE -->
  <section class="py-20 md:py-24 bg-bg-secondary">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-primary text-center mb-12">
        Este pentru compania ta dacă:
      </h2>
      <div class="max-w-3xl mx-auto">
        <div class="bg-white rounded-xl border border-border p-8 md:p-10">
          <ul class="space-y-5">
            {[
              'Ai cifra de afaceri de peste 500.000 EUR',
              'Generezi constant lead-uri — minim 50 pe lună',
              'Folosești deja un CRM (ActiveCampaign, HubSpot, Salesforce, Pipedrive etc.)',
              'Ai automatizări sau campanii active, dar știi că procesele pot produce mai mult',
              'Vinzi B2B sau B2C cu model de vânzare consultativă',
              'Vrei îmbunătățirea sistemului, nu doar setarea unor automatizări izolate',
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 w-5 h-5 rounded-full bg-success/15 flex items-center justify-center mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span class="text-text-primary font-medium">{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8 pt-6 border-t border-border">
            <p class="text-text-secondary leading-relaxed text-sm">
              Lucrez cu companii din orice industrie care au vânzare consultativă — de la servicii profesionale și clinici, la producători, centre de formare, și agenții.<br />
              <strong class="text-text-primary font-medium">Nu lucrez (încă) cu e-commerce.</strong>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CELE 3 ETAPE -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-primary text-center mb-16">
        Cum transform procesele în sisteme performante
      </h2>
      <div class="space-y-12">

        <!-- Etapa 1 -->
        <div class="grid md:grid-cols-5 gap-8 items-start">
          <div class="md:col-span-1">
            <div class="font-display text-7xl md:text-8xl font-bold text-accent/20 leading-none select-none">01</div>
          </div>
          <div class="md:col-span-4 bg-bg-secondary rounded-xl p-8 border border-border">
            <h3 class="font-sans text-2xl font-semibold text-primary mb-4">Audit &amp; plan strategic de automatizări</h3>
            <p class="text-text-secondary leading-relaxed mb-4">
              Începem cu un audit complet al modului în care funcționează marketingul și vânzările tale. Analizez în detaliu:
            </p>
            <ul class="space-y-2 mb-6 text-text-secondary">
              {[
                'Parcursul complet al clientului — de la prima interacțiune până post-achiziție',
                'Obiectivele de business și KPI-urile prin care măsurăm evoluția',
                'Fluxul de lead-uri: cum sunt captate, segmentate și gestionate',
                'Utilizarea CRM-ului și integrarea cu celelalte platforme',
                'Automatizările existente și impactul lor real',
                'Punctele unde se pierd lead-uri sau oportunități',
              ].map(item => (
                <li class="flex items-start gap-2">
                  <span class="text-accent-warm mt-1 flex-shrink-0">•</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <p class="text-text-secondary leading-relaxed mb-6">
              Pe baza auditului construiesc un plan personalizat care include: obiectivele prioritare, automatizările necesare ordonate după impact, optimizările proceselor existente, arhitectura sistemului, și un roadmap clar de implementare.
            </p>
            <p class="text-text-secondary leading-relaxed mb-6 font-medium text-text-primary">
              La finalul acestei etape, știi exact ce implementăm, în ce ordine și de ce.
            </p>
            <div class="flex flex-wrap gap-6 pt-4 border-t border-border">
              <div>
                <span class="text-xs text-text-tertiary uppercase tracking-wide font-semibold block mb-1">Investiție</span>
                <span class="font-semibold text-primary text-lg">1.500 – 2.500 €</span>
              </div>
              <div>
                <span class="text-xs text-text-tertiary uppercase tracking-wide font-semibold block mb-1">Durată</span>
                <span class="font-semibold text-primary text-lg">2–3 săptămâni</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Etapa 2 -->
        <div class="grid md:grid-cols-5 gap-8 items-start">
          <div class="md:col-span-1">
            <div class="font-display text-7xl md:text-8xl font-bold text-accent/20 leading-none select-none">02</div>
          </div>
          <div class="md:col-span-4 bg-bg-secondary rounded-xl p-8 border border-border">
            <h3 class="font-sans text-2xl font-semibold text-primary mb-4">Implementare &amp; consolidare</h3>
            <p class="text-text-secondary leading-relaxed mb-4">
              Construiesc și optimizez fluxurile care influențează direct performanța:
            </p>
            <ul class="space-y-2 mb-6 text-text-secondary">
              {[
                'Fluxuri de lead management — captare, calificare, distribuire',
                'Secvențe automate de nurturing și follow-up',
                'Integrare între CRM și celelalte tool-uri din stack',
                'Automatizări de retenție și reactivare',
                'Configurare raportare și dashboard-uri de monitorizare',
              ].map(item => (
                <li class="flex items-start gap-2">
                  <span class="text-accent-warm mt-1 flex-shrink-0">•</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <p class="text-text-secondary leading-relaxed mb-6">
              Implementarea este etapizată și controlată — fiecare automatizare este testată și validată înainte de a trece la următoarea.
            </p>
            <div class="flex flex-wrap gap-6 pt-4 border-t border-border">
              <div>
                <span class="text-xs text-text-tertiary uppercase tracking-wide font-semibold block mb-1">Investiție</span>
                <span class="font-semibold text-primary text-lg">3.000 – 5.000 €</span>
              </div>
              <div>
                <span class="text-xs text-text-tertiary uppercase tracking-wide font-semibold block mb-1">Durată</span>
                <span class="font-semibold text-primary text-lg">4–8 săptămâni</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Etapa 3 -->
        <div class="grid md:grid-cols-5 gap-8 items-start">
          <div class="md:col-span-1">
            <div class="font-display text-7xl md:text-8xl font-bold text-accent/20 leading-none select-none">03</div>
          </div>
          <div class="md:col-span-4 bg-bg-secondary rounded-xl p-8 border border-border">
            <h3 class="font-sans text-2xl font-semibold text-primary mb-4">Optimizare continuă &amp; creștere</h3>
            <p class="text-text-secondary leading-relaxed mb-4">
              Performanța este un proces, nu un proiect cu deadline.
            </p>
            <p class="text-text-secondary leading-relaxed mb-3">
              <strong class="text-text-primary font-medium">Lunar:</strong> analizăm indicatorii relevanți, identificăm oportunități de îmbunătățire, implementăm optimizări, ajustăm mesajele și fluxurile pe baza datelor.
            </p>
            <p class="text-text-secondary leading-relaxed mb-6">
              <strong class="text-text-primary font-medium">Trimestrial:</strong> evaluare strategică completă a rezultatelor, analiză de impact, plan de îmbunătățire pentru următorul trimestru.
            </p>
            <p class="text-text-secondary leading-relaxed mb-6 font-medium text-text-primary">
              Scopul: un sistem care crește constant în performanță, nu doar mentenanță.
            </p>
            <div class="flex flex-wrap gap-6 pt-4 border-t border-border">
              <div>
                <span class="text-xs text-text-tertiary uppercase tracking-wide font-semibold block mb-1">Retainer lunar</span>
                <span class="font-semibold text-primary text-lg">700 – 1.000 €</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CE OBTII CONCRET -->
  <section class="py-20 md:py-24 bg-bg-secondary">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-primary text-center mb-12">
        Ce obții concret
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            title: 'Conversii mai bune din același volum de lead-uri',
            body: 'Optimizez modul în care lead-urile sunt preluate, urmărite și transformate în clienți. Creștere tipică: 15–30% în rata de conversie lead–client în primele 6 luni.',
          },
          {
            title: 'Reducerea intervențiilor manuale cu 50–60%',
            body: 'Automatizez procesele repetitive: răspunsuri inițiale, follow-up, calificare, distribuire lead-uri, solicitare feedback.',
          },
          {
            title: 'Vizibilitate completă pe performanță',
            body: 'Știi exact ce funcționează, ce nu, și unde trebuie intervenit. Decizii bazate pe date, nu pe intuiție.',
          },
          {
            title: 'Un sistem integrat, nu automatizări izolate',
            body: 'CRM, email, formulare, raportare — totul conectat într-un singur sistem coerent.',
          },
          {
            title: 'Optimizare continuă, nu doar implementare',
            body: 'După lansare, monitorizez, testez și îmbunătățesc constant. Sistemul evoluează odată cu business-ul tău.',
          },
          {
            title: 'Structură clară pentru următorii pași',
            body: 'La fiecare trimestru, știi exact ce optimizăm, de ce, și ce impact așteptăm.',
          },
        ].map(card => (
          <div class="bg-white rounded-xl p-6 border border-border hover:shadow-md transition-shadow">
            <h3 class="font-sans text-base font-semibold text-primary mb-2 leading-snug">{card.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- URMATORII PASI -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-primary text-center mb-12">
        Următorii pași
      </h2>
      <div class="space-y-6 mb-10">
        {[
          {
            num: '1',
            title: 'Completezi formularul de mai jos',
            body: 'Îmi spui despre companie, provocări și obiective.',
          },
          {
            num: '2',
            title: 'Analizez informațiile',
            body: 'Evaluez contextul și mă asigur că există aliniere.',
          },
          {
            num: '3',
            title: 'Discuție de clarificare',
            body: 'Dacă profilul se potrivește, programăm o conversație de 30 minute.',
          },
        ].map(step => (
          <div class="flex items-start gap-5">
            <div class="w-8 h-8 rounded-full bg-accent text-white flex items-center justify-center font-semibold text-sm flex-shrink-0 mt-0.5">{step.num}</div>
            <div>
              <h3 class="font-semibold text-primary mb-1">{step.title}</h3>
              <p class="text-text-secondary">{step.body}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="text-text-secondary leading-relaxed italic text-sm text-center max-w-2xl mx-auto">
        Lucrez cu un număr limitat de companii simultan pentru a păstra implicarea strategică în fiecare proiect. De aceea, selectez proiectele în funcție de nivelul de aliniere și claritatea obiectivelor.
      </p>
    </div>
  </section>

  <!-- FORMULAR -->
  <section id="formular" class="py-20 md:py-24 bg-bg-secondary">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-primary text-center mb-4">
        Hai să discutăm despre procesele tale
      </h2>
      <p class="text-text-secondary text-center mb-10">
        Completează formularul de mai jos — analizez fiecare cerere personal și revin cu un răspuns personalizat.
      </p>

      <div class="bg-white rounded-xl border border-border p-8 md:p-10">
        <form id="contact-form" class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="prenume" class="block text-sm font-semibold text-text-primary mb-1.5">Prenume <span class="text-text-tertiary">*</span></label>
              <input type="text" id="prenume" name="prenume" required class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors" placeholder="Prenumele tău" />
            </div>
            <div>
              <label for="nume" class="block text-sm font-semibold text-text-primary mb-1.5">Nume <span class="text-text-tertiary">*</span></label>
              <input type="text" id="nume" name="nume" required class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors" placeholder="Numele tău" />
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-text-primary mb-1.5">Adresa de email <span class="text-text-tertiary">*</span></label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors" placeholder="adresa@companie.ro" />
          </div>
          <div>
            <label for="companie" class="block text-sm font-semibold text-text-primary mb-1.5">Numele companiei <span class="text-text-tertiary">*</span></label>
            <input type="text" id="companie" name="companie" required class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors" placeholder="Numele companiei" />
          </div>
          <div>
            <label for="site" class="block text-sm font-semibold text-text-primary mb-1.5">Site-ul companiei <span class="text-text-tertiary">*</span></label>
            <input type="url" id="site" name="site" required class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors" placeholder="https://" />
          </div>
          <div>
            <label for="provocare" class="block text-sm font-semibold text-text-primary mb-1.5">Care e cea mai mare provocare legată de automatizarea marketingului și vânzărilor? <span class="text-text-tertiary">*</span></label>
            <textarea id="provocare" name="provocare" required rows="4" class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors resize-y" placeholder="Ex: Generăm lead-uri dar conversiile sunt sub așteptări, echipa pierde timp pe procese manuale..."></textarea>
          </div>
          <div>
            <label for="lead_uri" class="block text-sm font-semibold text-text-primary mb-1.5">Câte lead-uri generați aproximativ pe lună?</label>
            <select id="lead_uri" name="lead_uri" class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors bg-white text-text-primary">
              <option value="">Selectează...</option>
              <option value="sub-50">Sub 50</option>
              <option value="50-100">50 – 100</option>
              <option value="100-300">100 – 300</option>
              <option value="peste-300">Peste 300</option>
            </select>
          </div>
          <div>
            <label for="crm" class="block text-sm font-semibold text-text-primary mb-1.5">Ce CRM folosiți?</label>
            <select id="crm" name="crm" class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors bg-white text-text-primary">
              <option value="">Selectează...</option>
              <option value="activecampaign">ActiveCampaign</option>
              <option value="hubspot">HubSpot</option>
              <option value="salesforce">Salesforce</option>
              <option value="pipedrive">Pipedrive</option>
              <option value="mailchimp">Mailchimp</option>
              <option value="zoho">Zoho CRM</option>
              <option value="altul">Altul</option>
              <option value="nu-folosim">Nu folosim CRM</option>
            </select>
          </div>
          <div>
            <label for="sursa" class="block text-sm font-semibold text-text-primary mb-1.5">Cum ai aflat de mine?</label>
            <select id="sursa" name="sursa" class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors bg-white text-text-primary">
              <option value="">Selectează...</option>
              <option value="recomandare">Recomandare</option>
              <option value="linkedin">LinkedIn</option>
              <option value="google">Căutare Google</option>
              <option value="blog">Blog / articol</option>
              <option value="altele">Altele</option>
            </select>
          </div>
          <div class="flex items-start gap-3">
            <input type="checkbox" id="gdpr" name="gdpr" required class="mt-1 h-4 w-4 rounded border-border text-primary focus:ring-primary-light flex-shrink-0" />
            <label for="gdpr" class="text-sm text-text-secondary">
              Sunt de acord cu prelucrarea datelor personale conform <a href="/politica-confidentialitate" class="text-primary-light hover:underline">Politicii de confidențialitate</a>. <span class="text-text-tertiary">*</span>
            </label>
          </div>
          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-accent hover:bg-accent-hover text-white font-semibold py-4 rounded-lg transition-all hover:-translate-y-px hover:shadow-md text-base"
          >
            Trimite cererea →
          </button>
          <p class="text-xs text-text-tertiary text-center">
            Analizez fiecare cerere personal. Dacă există aliniere, primești o invitație la o discuție de clarificare.
          </p>
        </form>
        <div id="form-success" class="hidden p-6 bg-success/10 border border-success/20 rounded-xl text-center">
          <div class="text-2xl mb-3">✓</div>
          <h3 class="font-semibold text-primary text-lg mb-2">Mulțumesc! Am primit cererea ta.</h3>
          <p class="text-text-secondary">Voi reveni cu un răspuns personalizat — urmărește-ți inbox-ul.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitBtn) {
      submitBtn.textContent = 'Se trimite...';
      submitBtn.disabled = true;
    }
    const data = new FormData(form!);
    try {
      await fetch('https://n8n.altia.work/webhook/e0be7221-eac8-4a96-91b5-eab5e259b09b', {
        method: 'POST',
        body: JSON.stringify({ source: 'formular-servicii', ...Object.fromEntries(data) }),
        headers: { 'Content-Type': 'application/json' },
      });
      form!.classList.add('hidden');
      successMsg?.classList.remove('hidden');
      (window as any).gtag?.('event', 'generate_lead', { form_name: 'servicii' });
      (window as any).fbq?.('track', 'Lead', { content_name: 'servicii' });
    } catch {
      // Show success anyway
      form!.classList.add('hidden');
      successMsg?.classList.remove('hidden');
      (window as any).gtag?.('event', 'generate_lead', { form_name: 'servicii' });
      (window as any).fbq?.('track', 'Lead', { content_name: 'servicii' });
    }
  });
</script>
