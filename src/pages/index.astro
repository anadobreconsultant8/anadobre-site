---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const blogPosts = [
  {
    slug: 'plan-lunar-continut-automatizare-ai',
    title: 'Cum poți construi un plan lunar de conținut cu ajutorul automatizării și agenților AI, fără să pierzi controlul',
    excerpt: 'Agenții AI pot genera structuri de conținut în secunde. Dar fără un sistem clar, ajungi cu mult conținut și puțin control.',
    category: 'Automatizări',
    date: '2026-01-15',
    image: '/blog/automatizare-orchestrare-agenti-ai-n8n-planificare-continut.png',
  },
  {
    slug: 'automatizari-whatsapp-business',
    title: 'Automatizări în WhatsApp Business: ce poți face concret ca antreprenor, direct din aplicație',
    excerpt: 'WhatsApp Business oferă mai mult decât mesaje automate de bun venit. Iată ce poți automatiza fără tool-uri externe.',
    category: 'WhatsApp Business',
    date: '2025-12-10',
    image: '/blog/automatizari-simple-whatsapp-business-scaled.jpeg',
  },
  {
    slug: 'nu-mai-pierde-lead-urile',
    title: 'Cum să nu mai pierzi lead-urile pe care le plătești deja',
    excerpt: 'Cele mai multe companii plătesc pentru lead-uri pe care nu le convertesc niciodată. Nu din lipsă de interes, ci din lipsă de proces.',
    category: 'Lead Management',
    date: '2025-11-20',
    image: '/blog/automatizari-marketing-lead-management.jpg',
  },
];
---
<Layout
  title="Ana Dobre — Automatizări Marketing & Vânzări pentru Companii în Creștere"
  description="Construiesc și optimizez sisteme automatizate de marketing și vânzări. Audit, implementare și optimizare continuă pentru companii cu CRM și 50+ lead-uri lunar."
>
  <Navbar />

  <!-- HERO -->
  <section class="relative py-20 md:py-28 overflow-hidden" style="background-color:#0d1b35;">

    <!-- Animated network canvas -->
    <canvas id="hero-canvas" style="position:absolute;inset:0;width:100%;height:100%;z-index:0;"></canvas>

    <div class="relative max-w-4xl mx-auto px-6 text-center" style="position:relative;z-index:1;">
      <div class="inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-6" style="color:#7eb8f7;border:1px solid rgba(126,184,247,0.3);background:transparent;">
        Automatizări marketing &amp; vânzări
      </div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6" style="color:white;">
        Sistemul tău de marketing generează lead-uri.<br />
        <span style="color:#4d9ef7;">Dar câte devin clienți?</span>
      </h1>
      <p class="text-lg md:text-xl leading-relaxed mb-10 max-w-2xl mx-auto" style="color:rgba(255,255,255,0.78);">
        Construiesc și optimizez sisteme automatizate de marketing și vânzări pentru companii care au CRM, generează 50+ lead-uri lunar, și vor ca procesele lor să producă mai mulți clienți din același efort.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/mini-audit" class="font-semibold px-8 py-4 rounded-lg transition-all hover:-translate-y-px hover:shadow-xl text-base" style="background:#E8593C;color:white;" onmouseover="this.style.background='#D04A2E'" onmouseout="this.style.background='#E8593C'">
          Evaluează-ți sistemul →
        </a>
        <a href="/servicii#formular" class="font-medium px-6 py-3.5 rounded-lg transition-all text-sm" style="background:transparent;color:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.55);" onmouseover="this.style.background='rgba(255,255,255,0.08)'" onmouseout="this.style.background='transparent'">
          Programează o discuție
        </a>
      </div>
      <!-- Tool badges -->
      <div class="mt-12">
        <p class="text-xs uppercase tracking-widest mb-4" style="color:rgba(255,255,255,0.4);">Sisteme construite cu:</p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          {['ActiveCampaign', 'n8n', 'Zapier', 'Mailchimp'].map(tool => (
            <span class="text-sm font-semibold px-4 py-2 rounded-lg" style="color:#7eb8f7;border:1px solid rgba(126,184,247,0.25);background:rgba(126,184,247,0.06);">{tool}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEMA -->

  <section class="py-20 md:py-24 bg-bg-secondary">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-primary text-center mb-12">
        Recunoști situația?
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            title: 'Lead-urile vin, dar conversiile nu cresc proporțional.',
            body: 'Investești constant în marketing și generezi lead-uri, dar rata de conversie lead–client rămâne sub potențial. Echipa intervine manual mai mult decât ar trebui, iar unele oportunități se pierd pe drum.',
          },
          {
            title: 'Automatizările există, dar nu lucrează împreună.',
            body: 'Ai fluxuri active, dar fiecare funcționează izolat. CRM-ul nu e integrat cu formularele, emailurile nu se adaptează la stadiul lead-ului, iar datele sunt fragmentate în mai multe platforme.',
          },
          {
            title: 'Optimizezi pe intuiție, mai puțin pe date.',
            body: 'Nu ai vizibilitate clară pe ce funcționează și ce nu. Deciziile de marketing se iau pe baza sentimentului, nu pe baza unui sistem care îți arată exact unde pierzi și unde câștigi.',
          },
        ].map(card => (
          <div class="bg-white border border-border rounded-xl p-8 hover:shadow-lg transition-shadow">
            <h3 class="font-sans text-lg font-semibold text-primary mb-4 leading-snug">{card.title}</h3>
            <p class="text-text-secondary leading-relaxed text-base">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CE OBTII -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-3">Ce se schimbă când lucrăm împreună</p>
        <h2 class="font-display text-3xl md:text-4xl font-semibold text-primary max-w-2xl mx-auto leading-tight">
          Transform procesele de marketing și vânzări într-un sistem care produce rezultate măsurabile.
        </h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            num: '01',
            title: 'Conversie mai mare din același volum de lead-uri',
            body: 'Optimizez parcursul complet al lead-ului — de la prima interacțiune până la contract — eliminând punctele unde se pierd oportunități.',
          },
          {
            num: '02',
            title: 'Procese care funcționează fără intervenție manuală constantă',
            body: 'Construiesc automatizări integrate care preiau, califică, urmăresc și convertesc lead-uri sistematic.',
          },
          {
            num: '03',
            title: 'Decizii bazate pe date',
            body: 'Implementez raportare și KPI-uri care arată exact unde merge bine și unde trebuie intervenit.',
          },
          {
            num: '04',
            title: 'Un partener strategic, nu un executant de task-uri',
            body: 'Lucrez ca extensie a echipei tale: audit, strategie, implementare, optimizare continuă.',
          },
        ].map(item => (
          <div class="flex gap-6 p-6 rounded-xl hover:bg-bg-secondary transition-colors border-l-2 border-transparent hover:border-accent">
            <span class="font-display text-4xl font-bold text-bg-tertiary flex-shrink-0 leading-none mt-1 select-none">{item.num}</span>
            <div>
              <h3 class="font-sans text-lg font-semibold text-primary mb-2">{item.title}</h3>
              <p class="text-text-secondary leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CUM FUNCTIONEAZA -->
  <section class="py-20 md:py-24 bg-bg-secondary">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-primary text-center mb-12">
        Cum funcționează o colaborare
      </h2>
      <div class="grid md:grid-cols-3 gap-8 mb-12">
        {[
          {
            num: '01',
            title: 'Audit & strategie',
            body: 'Analizez procesele existente, identific punctele de pierdere, și construiesc un plan de automatizare prioritizat pe baza impactului. Primești un document complet cu harta fluxurilor, recomandări concrete, și un roadmap clar.',
          },
          {
            num: '02',
            title: 'Implementare',
            body: 'Construiesc și conectez automatizările etapizat: CRM, emailuri, formulare, integrări. Fiecare flux este testat înainte de a trece la următorul. Durata: 4–8 săptămâni.',
          },
          {
            num: '03',
            title: 'Optimizare continuă',
            body: 'Lunar, analizăm rezultatele și ajustăm. La fiecare trimestru, evaluare strategică completă. Sistemul evoluează odată cu business-ul tău.',
          },
        ].map(step => (
          <div class="bg-white rounded-xl p-8 border border-border hover:border-primary/30 hover:shadow-md transition-all">
            <div class="font-display text-5xl font-bold text-accent/20 mb-4 leading-none select-none">{step.num}</div>
            <h3 class="font-sans text-xl font-semibold text-primary mb-3">{step.title}</h3>
            <p class="text-text-secondary leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
      <div class="text-center">
        <a href="/servicii" class="bg-accent hover:bg-accent-hover text-white font-semibold px-8 py-4 rounded-lg transition-all hover:-translate-y-px hover:shadow-lg inline-block">
          Vezi detalii și prețuri →
        </a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALE -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-primary text-center mb-12">
        Ce spun companiile cu care am lucrat
      </h2>

      <!-- Carousel wrapper -->
      <div class="relative">
        <div id="testimonials-track" class="overflow-hidden">
          <!-- Slide 1 -->
          <div class="testimonial-slide grid md:grid-cols-3 gap-8">
            <div class="bg-bg-secondary rounded-xl p-8 border border-border flex flex-col">
              <blockquote class="text-text-secondary leading-relaxed italic flex-1 mb-6 text-base">
                "Lucrăm împreună cu Ana de peste 4 ani, timp în care am abordat cam toate modalitățile de promovare online. Profesionalismul abordării și competențele mereu actualizate ne-au adus poziționare și vizibilitate online traduse în creșterea vânzărilor."
              </blockquote>
              <div class="flex items-center gap-3">
                <img src="/iulian-dinica-docsys.jpeg" alt="Iulian Dinică" class="w-10 h-10 rounded-full object-cover flex-shrink-0 border border-border" />
                <div>
                  <div class="font-semibold text-sm text-primary">Iulian Dinică</div>
                  <div class="text-xs text-text-tertiary">Managing Partner, Document Imaging Systems</div>
                </div>
              </div>
            </div>
            <div class="bg-bg-secondary rounded-xl p-8 border border-border flex flex-col">
              <blockquote class="text-text-secondary leading-relaxed italic flex-1 mb-6 text-base">
                "Am admirat la Ana capacitatea de a înțelege și pune în practică nu doar aspectele tehnice ale comunicării în mediul online, dar și nevoile strategice ale unui brand. O recomand oricărui business care are nevoie de suport profesionist în creșterea brandurilor."
              </blockquote>
              <div class="flex items-center gap-3">
                <img src="/mona-ursu-bf.jpeg" alt="Mona Ursu" class="w-10 h-10 rounded-full object-cover flex-shrink-0 border border-border" />
                <div>
                  <div class="font-semibold text-sm text-primary">Mona Ursu</div>
                  <div class="text-xs text-text-tertiary">Founder & CEO, Brandfusion</div>
                </div>
              </div>
            </div>
            <div class="bg-bg-secondary rounded-xl p-8 border border-border flex flex-col">
              <blockquote class="text-text-secondary leading-relaxed italic flex-1 mb-6 text-base">
                "Am apreciat profesionalismul ei și abordarea pragmatică. Lucrurile s-au întâmplat repede și cu rezultate foarte bune. O recomand antreprenorilor care doresc vizibilitate în manieră eficientă, într-un spațiu de colaborare sigur și profesionist."
              </blockquote>
              <div class="flex items-center gap-3">
                <img src="/manuela-ciugudean.jpeg" alt="Manuela Ciugudean" class="w-10 h-10 rounded-full object-cover flex-shrink-0 border border-border" />
                <div>
                  <div class="font-semibold text-sm text-primary">Manuela Ciugudean</div>
                  <div class="text-xs text-text-tertiary">Coach & Personal Brand Strategist</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Slide 2 -->
          <div class="testimonial-slide grid md:grid-cols-3 gap-8 hidden">
            <div class="bg-bg-secondary rounded-xl p-8 border border-border flex flex-col">
              <blockquote class="text-text-secondary leading-relaxed italic flex-1 mb-6 text-base">
                "Când am cunoscut-o pe Ana știam că ne dorim să creștem vizibilitatea brandului nostru de angajator în mediul online, însă nu știam cum să facem acest lucru cât mai eficient. Ana a venit cu un portofoliu de opțiuni, ne-a ajutat să le adaptăm brandului nostru și ne-a fost alături în crearea unei strategii sustenabile pentru digital marketing. O recomand din toată inima, nu doar pentru abilitățile și cunoștințele pe care le are, ci și pentru atitudinea ei orientată spre rezultate și răbdarea de care a dat dovadă."
              </blockquote>
              <div class="flex items-center gap-3">
                <img src="/monica-moldovean.jpeg" alt="Monica Moldovean" class="w-10 h-10 rounded-full object-cover flex-shrink-0 border border-border" />
                <div>
                  <div class="font-semibold text-sm text-primary">Monica Moldovean</div>
                  <div class="text-xs text-text-tertiary">ex Program Manager Communication, Employer Branding & Employee Engagement, Genpact</div>
                </div>
              </div>
            </div>
            <div class="bg-bg-secondary rounded-xl p-8 border border-border flex flex-col">
              <blockquote class="text-text-secondary leading-relaxed italic flex-1 mb-6 text-base">
                "Cât timp am colaborat, m-am bucurat de profesionalismul și promptitudinea pe care o căutăm cu toții zi de zi, de idei de creare a strategiei companiei pe care o reprezint chiar și în ziua de azi. Cu ajutorul Anei, am reușit să găsim canalul de promovare potrivit și adaptat profilului companiei. Am primit și simțit empatie, dedicare și profesionalism din partea ta."
              </blockquote>
              <div class="flex items-center gap-3">
                <img src="/sorina-netu.jpeg" alt="Sorina Nețu" class="w-10 h-10 rounded-full object-cover flex-shrink-0 border border-border" />
                <div>
                  <div class="font-semibold text-sm text-primary">Sorina Nețu</div>
                  <div class="text-xs text-text-tertiary">Marketing Director, Briaris IND SA</div>
                </div>
              </div>
            </div>
            <div class="bg-bg-secondary rounded-xl p-8 border border-border flex flex-col">
              <blockquote class="text-text-secondary leading-relaxed italic flex-1 mb-6 text-base">
                "Am apelat la Ana mulțumită unei recomandări și a reușit în ședințele pe care le-am făcut să învețe întreaga echipă să înțeleagă bazele și să lucreze pe partea de SEO. Ana ne-a învățat „să pescuim" — am făcut un training, ne-a răspuns la toate întrebările, am lucrat exemple practice împreună și am făcut un plan de acțiune. Atitudinea ei pozitivă și pragmatismul ajută foarte mult, așa că aș recomanda-o oricând."
              </blockquote>
              <div class="flex items-center gap-3">
                <img src="/anda-stan.jpeg" alt="Anda Stan" class="w-10 h-10 rounded-full object-cover flex-shrink-0 border border-border" />
                <div>
                  <div class="font-semibold text-sm text-primary">Anda Stan</div>
                  <div class="text-xs text-text-tertiary">Owner, TravelShip.ro</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-center gap-6 mt-10">
          <button id="t-prev" class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-text-tertiary hover:border-primary hover:text-primary transition-colors disabled:opacity-30 disabled:cursor-not-allowed" aria-label="Anterior" disabled>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <div class="flex gap-2">
            <button class="t-dot w-2.5 h-2.5 rounded-full bg-primary transition-colors" data-index="0" aria-label="Slide 1"></button>
            <button class="t-dot w-2.5 h-2.5 rounded-full bg-border transition-colors" data-index="1" aria-label="Slide 2"></button>
          </div>
          <button id="t-next" class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-text-tertiary hover:border-primary hover:text-primary transition-colors" aria-label="Următor">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- LEAD MAGNET + NEWSLETTER -->
  <section class="py-20 md:py-24 bg-bg-secondary">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Mini-audit -->
        <div class="bg-white rounded-xl p-8 border border-border">
          <h3 class="font-sans text-xl font-semibold text-primary mb-4">Vrei să știi unde pierzi lead-uri?</h3>
          <p class="text-text-secondary leading-relaxed mb-6">
            Răspunde la 8 întrebări despre procesele tale de marketing și vânzări. Primești un raport cu scorul tău de maturitate și recomandări concrete — gratuit, fără obligații.
          </p>
          <a href="/mini-audit" class="bg-accent hover:bg-accent-hover text-white font-semibold px-6 py-3 rounded-lg transition-all hover:-translate-y-px hover:shadow-md inline-block">
            Începe evaluarea →
          </a>
        </div>
        <!-- Newsletter -->
        <div class="bg-white rounded-xl p-8 border border-border">
          <h3 class="font-sans text-xl font-semibold text-primary mb-4">Strategii de automatizare, direct în inbox.</h3>
          <p class="text-text-secondary leading-relaxed mb-6">
            O dată la 2 săptămâni: studii de caz, greșeli frecvente, recomandări testate în piață. Conținut pentru cei care vor sisteme mai bune de marketing și vânzări.
          </p>
          <form id="newsletter-form" class="space-y-3">
            <input
              type="text"
              name="prenume"
              placeholder="Prenumele tău"
              required
              class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors"
            />
            <input
              type="email"
              name="email"
              placeholder="Adresa de email"
              required
              class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors"
            />
            <div class="flex items-start gap-2">
              <input type="checkbox" id="newsletter-gdpr" name="gdpr" required class="mt-0.5 h-4 w-4 rounded border-border text-primary flex-shrink-0" />
              <label for="newsletter-gdpr" class="text-xs text-text-secondary leading-relaxed">
                Sunt de acord cu prelucrarea datelor personale conform <a href="/politica-confidentialitate" class="text-primary-light hover:underline">Politicii de confidențialitate</a>. *
              </label>
            </div>
            <button
              type="submit"
              class="w-full bg-accent hover:bg-accent-hover text-white font-semibold py-3 rounded-lg transition-all hover:-translate-y-px hover:shadow-md"
            >
              Abonează-te
            </button>
            <p class="text-xs text-text-tertiary text-center">Zero spam. Te poți dezabona oricând.</p>
          </form>
          <div id="newsletter-success" class="hidden mt-4 p-4 bg-success/10 text-success rounded-lg text-sm font-medium text-center">
            ✓ Mulțumesc! Te-ai abonat cu succes.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center justify-between mb-12">
        <h2 class="font-display text-3xl md:text-4xl font-semibold text-primary">De pe blog</h2>
        <a href="/blog" class="text-sm font-medium text-primary-light hover:text-primary transition-colors hidden sm:flex items-center gap-1">
          Toate articolele →
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {blogPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="group block bg-white border border-border rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
            <img src={post.image} alt={post.title} class="aspect-video w-full object-cover" loading="lazy" />
            <div class="p-6">
              <span class="inline-block bg-bg-tertiary text-primary text-xs font-semibold uppercase tracking-wide px-2 py-0.5 rounded-full mb-3">
                {post.category}
              </span>
              <h3 class="font-sans text-base font-semibold text-primary mb-2 leading-snug group-hover:text-primary-light transition-colors">
                {post.title}
              </h3>
              <p class="text-text-secondary text-sm leading-relaxed mb-4 line-clamp-2">{post.excerpt}</p>
              <time class="text-xs text-text-tertiary">
                {new Date(post.date).toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-10 sm:hidden">
        <a href="/blog" class="text-sm font-medium text-primary-light hover:text-primary transition-colors">
          Toate articolele →
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  // Hero canvas — animated network graph
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;

    function resize() {
      canvas!.width = canvas!.offsetWidth;
      canvas!.height = canvas!.offsetHeight;
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    const nodes = Array.from({ length: 60 }, () => ({
      x: Math.random() * canvas!.width,
      y: Math.random() * canvas!.height,
      vx: (Math.random() - 0.5) * 0.4,
      vy: (Math.random() - 0.5) * 0.4,
      r: Math.random() * 2 + 1,
    }));

    function draw() {
      ctx.clearRect(0, 0, canvas!.width, canvas!.height);
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 140) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(126,184,247,${(1 - dist / 140) * 0.25})`;
            ctx.lineWidth = 0.8;
            ctx.moveTo(nodes[i].x, nodes[i].y);
            ctx.lineTo(nodes[j].x, nodes[j].y);
            ctx.stroke();
          }
        }
      }
      nodes.forEach(n => {
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(180,210,255,0.6)';
        ctx.fill();
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < 0 || n.x > canvas!.width) n.vx *= -1;
        if (n.y < 0 || n.y > canvas!.height) n.vy *= -1;
      });
      requestAnimationFrame(draw);
    }
    draw();
  }
</script>

<script>
  // Testimonials carousel
  const slides = document.querySelectorAll<HTMLElement>('.testimonial-slide');
  const dots = document.querySelectorAll<HTMLButtonElement>('.t-dot');
  const prevBtn = document.getElementById('t-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('t-next') as HTMLButtonElement | null;
  let current = 0;

  function goTo(index: number) {
    slides[current].classList.add('hidden');
    dots[current].classList.remove('bg-primary');
    dots[current].classList.add('bg-border');
    current = index;
    slides[current].classList.remove('hidden');
    dots[current].classList.add('bg-primary');
    dots[current].classList.remove('bg-border');
    if (prevBtn) prevBtn.disabled = current === 0;
    if (nextBtn) nextBtn.disabled = current === slides.length - 1;
  }

  prevBtn?.addEventListener('click', () => { if (current > 0) goTo(current - 1); });
  nextBtn?.addEventListener('click', () => { if (current < slides.length - 1) goTo(current + 1); });
  dots.forEach(dot => dot.addEventListener('click', () => goTo(Number(dot.dataset.index))));

  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('newsletter-success');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form!);
    try {
      const res = await fetch('/api/newsletter-subscribe', {
        method: 'POST',
        body: JSON.stringify(Object.fromEntries(data)),
        headers: { 'Content-Type': 'application/json' },
      });
      if (res.ok) {
        form!.classList.add('hidden');
        successMsg?.classList.remove('hidden');
      }
    } catch {
      // Show success anyway for static build
      form!.classList.add('hidden');
      successMsg?.classList.remove('hidden');
    }
  });
</script>
