---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Contact — Ana Dobre | Automatizări Marketing & Vânzări"
  description="Contactează-mă pentru orice întrebare. Cea mai rapidă cale: completează formularul de pe pagina de servicii."
>
  <Navbar />

  <!-- Hero -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-primary mb-4">Contact</h1>
      <p class="text-lg text-text-secondary leading-relaxed max-w-xl">
        Cea mai rapidă cale: completează formularul de pe pagina de servicii.<br />
        Pentru orice altceva, scrie-mi direct.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-8 pb-24 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12">

        <!-- Left — contact info -->
        <div>
          <h2 class="font-sans text-xl font-semibold text-primary mb-6">Date de contact</h2>
          <div class="space-y-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-bg-tertiary rounded-lg flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-text-tertiary uppercase tracking-wide font-semibold mb-1">Email</div>
                <a href="mailto:hello@anadobre.com" class="text-primary-light hover:text-primary transition-colors font-medium">
                  hello@anadobre.com
                </a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-bg-tertiary rounded-lg flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-text-secondary" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
              </div>
              <div>
                <div class="text-xs text-text-tertiary uppercase tracking-wide font-semibold mb-1">LinkedIn</div>
                <a href="https://www.linkedin.com/in/anadobreconsultant/" target="_blank" rel="noopener noreferrer" class="text-primary-light hover:text-primary transition-colors font-medium">
                  linkedin.com/in/anadobreconsultant
                </a>
              </div>
            </div>
          </div>

          <div class="mt-10 p-6 bg-bg-secondary rounded-xl border border-border">
            <p class="text-sm text-text-secondary leading-relaxed mb-4">
              Dacă vrei să discutăm despre o colaborare, cea mai eficientă cale este formularul detaliat de pe pagina de servicii — îmi permite să înțeleg contextul înainte de discuție.
            </p>
            <a href="/servicii#formular" class="bg-accent hover:bg-accent-hover text-white font-semibold px-5 py-2.5 rounded-lg transition-all hover:-translate-y-px hover:shadow-md inline-block text-sm">
              Completează formularul de servicii →
            </a>
          </div>
        </div>

        <!-- Right — simple form -->
        <div>
          <h2 class="font-sans text-xl font-semibold text-primary mb-6">Trimite un mesaj</h2>
          <form id="contact-simple-form" class="space-y-4">
            <div>
              <label for="contact-name" class="block text-sm font-semibold text-text-primary mb-1.5">Numele tău</label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                placeholder="Prenume și nume"
                class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors"
              />
            </div>
            <div>
              <label for="contact-email" class="block text-sm font-semibold text-text-primary mb-1.5">Email</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                placeholder="adresa@companie.ro"
                class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors"
              />
            </div>
            <div>
              <label for="contact-message" class="block text-sm font-semibold text-text-primary mb-1.5">Mesaj</label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="5"
                placeholder="Scrie-mi..."
                class="w-full px-4 py-3 border border-border rounded-lg text-sm focus:outline-none focus:border-primary-light focus:ring-1 focus:ring-primary-light transition-colors resize-y"
              ></textarea>
            </div>
            <div class="flex items-start gap-2.5">
              <input type="checkbox" id="contact-gdpr" name="gdpr" required class="mt-0.5 h-4 w-4 rounded border-border text-accent focus:ring-accent flex-shrink-0" />
              <label for="contact-gdpr" class="text-xs text-text-secondary leading-relaxed">
                Sunt de acord cu prelucrarea datelor personale conform <a href="/politica-confidentialitate" class="text-primary-light hover:underline">Politicii de confidențialitate</a>. <span class="text-text-tertiary">*</span>
              </label>
            </div>
            <button
              type="submit"
              class="w-full bg-accent hover:bg-accent-hover text-white font-semibold py-3 rounded-lg transition-all hover:-translate-y-px hover:shadow-md"
            >
              Trimite mesajul
            </button>
          </form>
          <div id="contact-success" class="hidden mt-4 p-4 bg-success/10 text-success rounded-lg text-sm font-medium text-center">
            ✓ Mesajul a fost trimis. Îți voi răspunde în curând!
          </div>
          <p class="text-xs text-text-tertiary mt-3 text-center">
            Sau programează direct o discuție →
            <a href="/servicii#formular" class="text-primary-light hover:text-primary transition-colors underline">completează formularul de servicii</a>
          </p>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-simple-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form!);
    try {
      await fetch('https://n8n.altia.work/webhook-test/f74e1ccc-8143-4360-8750-22a1259f5b6a', {
        method: 'POST',
        body: JSON.stringify({ source: 'formular-contact', ...Object.fromEntries(data) }),
        headers: { 'Content-Type': 'application/json' },
      });
    } catch { /* silent */ }
    form!.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>
