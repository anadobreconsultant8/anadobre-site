---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug);

if (!post) {
  return Astro.redirect('/blog');
}

const { Content } = await post.render();

const { title, date, category, image, excerpt } = post.data;

// Fetch all posts for related articles
const allPosts = await getCollection('blog');
const otherPosts = allPosts
  .filter((p) => p.slug !== slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
// Show up to 2 posts from same category first, then fill from others
const sameCat = otherPosts.filter((p) => p.data.category === category);
const diffCat = otherPosts.filter((p) => p.data.category !== category);
const relatedPosts = [...sameCat, ...diffCat].slice(0, 2);
---
<Layout title={`${title} — Ana Dobre`} description={excerpt ?? title}>
  <Navbar />

  <!-- Article -->
  <article class="py-16 md:py-20 bg-white">
    <div class="max-w-2xl mx-auto px-6">

      <!-- Meta -->
      <div class="flex items-center gap-3 mb-6">
        <span class="inline-block bg-bg-tertiary text-primary text-xs font-semibold uppercase tracking-wide px-2 py-0.5 rounded-full">
          {category}
        </span>
        <span class="text-xs text-text-tertiary">·</span>
        <time class="text-xs text-text-tertiary">
          {new Date(date).toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
      </div>

      <!-- Title -->
      <h1 class="font-display text-3xl md:text-4xl font-bold text-primary leading-tight mb-8">
        {title}
      </h1>

      <!-- Featured image -->
      {image ? (
        <div class="aspect-video rounded-xl border border-border overflow-hidden mb-10">
          <img
            src={image}
            alt={title}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      ) : (
        <div class="aspect-video bg-bg-tertiary rounded-xl border border-border flex items-center justify-center text-text-tertiary text-sm mb-10">
          Imagine articol — {category}
        </div>
      )}

      <!-- Content -->
      <div
        class="prose prose-lg max-w-none
          prose-headings:font-sans prose-headings:font-semibold prose-headings:text-primary
          prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
          prose-p:text-text-secondary prose-p:leading-relaxed prose-p:mb-5
          prose-ul:text-text-secondary prose-li:mb-2
          prose-strong:text-text-primary prose-strong:font-semibold
          prose-a:text-primary-light prose-a:no-underline hover:prose-a:underline"
      >
        <Content />
      </div>

    </div>
  </article>

  <!-- CTA Box -->
  <section class="py-12 bg-bg-secondary">
    <div class="max-w-2xl mx-auto px-6">
      <div class="bg-white rounded-xl p-8 border border-border text-center">
        <h3 class="font-sans text-xl font-semibold text-primary mb-3">
          Vrei să discutăm despre automatizarea proceselor din compania ta?
        </h3>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/servicii#formular" class="bg-accent hover:bg-accent-hover text-white font-semibold px-6 py-3 rounded-lg transition-all hover:-translate-y-px hover:shadow-md inline-block">
            Programează o discuție →
          </a>
          <a href="/mini-audit" class="border-2 border-primary text-primary hover:bg-primary hover:text-white font-semibold px-6 py-3 rounded-lg transition-all inline-block">
            Evaluează-ți sistemul gratuit
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Articles -->
  {relatedPosts.length > 0 && (
    <section class="py-16 md:py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="font-display text-2xl md:text-3xl font-semibold text-primary mb-8">Articole similare</h2>
        <div class="grid md:grid-cols-2 gap-8">
          {relatedPosts.map((related) => (
            <a href={`/blog/${related.slug}`} class="group block bg-white border border-border rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
              {related.data.image ? (
                <div class="aspect-video overflow-hidden">
                  <img
                    src={related.data.image}
                    alt={related.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="aspect-video bg-bg-tertiary flex items-center justify-center text-text-tertiary text-xs p-4 text-center">
                  Imagine articol
                </div>
              )}
              <div class="p-6">
                <span class="inline-block bg-bg-tertiary text-primary text-xs font-semibold uppercase tracking-wide px-2 py-0.5 rounded-full mb-3">
                  {related.data.category}
                </span>
                <h3 class="font-sans text-base font-semibold text-primary mb-2 leading-snug group-hover:text-primary-light transition-colors">
                  {related.data.title}
                </h3>
                <p class="text-text-secondary text-sm leading-relaxed mb-3">{related.data.excerpt}</p>
                <time class="text-xs text-text-tertiary">
                  {new Date(related.data.date).toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer />
</Layout>
