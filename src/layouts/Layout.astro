---
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
}
const { title, description, ogImage = '/og-default.jpg', canonical, noindex = false } = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site || 'https://anadobre.com').toString();

// ⚠️  Înlocuiește cu ID-urile reale când sunt disponibile:
const GA4_ID = 'G-HQ3N36DE0Z';
---
<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://anadobre.com${ogImage}`} />
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="msvalidate.01" content="A353177426BCAF890410D467283312CC" />

  <!-- ═══ Google Consent Mode v2 — TREBUIE să fie primul script ═══ -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}

    // Implicit: toate categoriile respinse
    gtag('consent', 'default', {
      'analytics_storage': 'denied',
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'wait_for_update': 500
    });

    // Restaurează consimțământul salvat anterior (înainte să se încarce GA4)
    try {
      var _c = JSON.parse(localStorage.getItem('cookie_consent') || 'null');
      if (_c && _c.timestamp) {
        gtag('consent', 'update', {
          'analytics_storage': _c.analytics ? 'granted' : 'denied',
          'ad_storage': _c.marketing ? 'granted' : 'denied',
          'ad_user_data': _c.marketing ? 'granted' : 'denied',
          'ad_personalization': _c.marketing ? 'granted' : 'denied',
        });
      }
    } catch(e) {}
  </script>

  <!-- ═══ Google Analytics 4 ═══ -->
<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
  <script is:inline define:vars={{ GA4_ID }}>
    gtag('js', new Date());
    gtag('config', GA4_ID, { 'anonymize_ip': true });
  </script>
  <!-- ════════════════════════════════════════════════════════════════ -->

  <!-- ═══ Facebook Pixel stub — coadă fără să încarce fbevents.js ═══ -->
  <script is:inline>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){
    n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];}
    (window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
  </script>
  <!-- ════════════════════════════════════════════════════════════════ -->

  <!-- ═══ Schema.org JSON-LD ═══ -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://anadobre.com/#website",
        "url": "https://anadobre.com",
        "name": "Ana Dobre",
        "description": "Construiesc și optimizez sisteme automatizate de marketing și vânzări pentru companii care vor să crească fără să adauge oameni.",
        "inLanguage": "ro",
        "publisher": { "@id": "https://anadobre.com/#person" }
      },
      {
        "@type": "Person",
        "@id": "https://anadobre.com/#person",
        "name": "Ana Dobre",
        "url": "https://anadobre.com",
        "image": "https://anadobre.com/ana-dobre-new.jpg",
        "jobTitle": "Consultant Marketing Automation",
        "description": "14+ ani de marketing digital, cu focus pe automatizări de marketing și vânzări, CRM, lead management și sisteme integrate.",
        "sameAs": [
          "https://www.linkedin.com/in/anadobreconsultant/"
        ],
        "knowsAbout": [
          "Marketing Automation",
          "CRM Integration",
          "Lead Management",
          "ActiveCampaign",
          "n8n",
          "Email Marketing",
          "Digital Marketing Strategy",
          "Sales Funnels"
        ],
        "worksFor": {
          "@type": "Organization",
          "name": "PFA Dobre N. Ana-Daniela",
          "url": "https://anadobre.com"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "url": "https://anadobre.com/contact",
          "availableLanguage": "Romanian"
        }
      }
    ]
  }
  </script>
</head>
<body class="font-sans text-text-primary bg-white antialiased">
  <slot />
  <CookieConsent />

  <!-- ═══ WebMCP — tool-uri pentru agenți AI ═══ -->
  <script is:inline>
  if (typeof navigator !== 'undefined' && navigator.modelContext) {
    const ac = new AbortController();

    navigator.modelContext.registerTool({
      name: 'get_site_info',
      title: 'Informații site Ana Dobre',
      description: 'Returnează informații despre Ana Dobre, serviciile oferite și modalitățile de contact.',
      annotations: { readOnlyHint: true },
      inputSchema: { type: 'object', properties: {} },
      execute: async () => ({
        name: 'Ana Dobre',
        role: 'Consultant Marketing Automation & Strategie Digitală',
        experience: '14+ ani marketing digital',
        services: ['Audit sisteme automatizare', 'Implementare marketing automation', 'Retainer consultanță'],
        contact: 'https://anadobre.com/contact',
        blog: 'https://anadobre.com/blog',
        mini_audit: 'https://anadobre.com/mini-audit',
      }),
    }, { signal: ac.signal });

    navigator.modelContext.registerTool({
      name: 'subscribe_newsletter',
      title: 'Abonare newsletter',
      description: 'Abonează utilizatorul la newsletter-ul despre marketing automation și strategie digitală.',
      inputSchema: {
        type: 'object',
        required: ['email'],
        properties: {
          prenume: { type: 'string', description: 'Prenumele utilizatorului' },
          email: { type: 'string', format: 'email', description: 'Adresa de email' },
        },
      },
      execute: async (input) => {
        const res = await fetch('/api/newsletter-subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prenume: input.prenume || '', email: input.email }),
        });
        const data = await res.json();
        return res.ok ? { success: true, message: 'Abonat cu succes.' } : { success: false, error: data.error };
      },
    }, { signal: ac.signal });

    navigator.modelContext.registerTool({
      name: 'get_blog_posts',
      title: 'Articole blog',
      description: 'Returnează lista de articole disponibile pe blog despre marketing automation, AI și strategie digitală.',
      annotations: { readOnlyHint: true },
      inputSchema: { type: 'object', properties: {} },
      execute: async () => {
        const res = await fetch('/blog', { headers: { 'Accept': 'text/markdown' } });
        const text = await res.text();
        return { url: 'https://anadobre.com/blog', content: text.slice(0, 3000) };
      },
    }, { signal: ac.signal });

    navigator.modelContext.registerTool({
      name: 'start_mini_audit',
      title: 'Pornire mini-audit',
      description: 'Direcționează utilizatorul către mini-auditul de maturitate în automatizări de marketing și vânzări.',
      annotations: { readOnlyHint: true },
      inputSchema: { type: 'object', properties: {} },
      execute: async (_, client) => {
        if (client && client.requestUserInteraction) {
          await client.requestUserInteraction(() => {
            window.location.href = '/mini-audit';
          });
        }
        return { url: 'https://anadobre.com/mini-audit', description: 'Mini-audit gratuit în 8 întrebări, 3 minute. Scor de maturitate + recomandări personalizate.' };
      },
    }, { signal: ac.signal });
  }
  </script>
  <!-- ════════════════════════════════════════════════════════════════ -->
</body>
</html>
